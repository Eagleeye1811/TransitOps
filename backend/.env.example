# Copy to .env and fill in real values before deploying.
# Local dev works with zero setup — DATABASE_URL defaults to SQLite if unset.

ENVIRONMENT=development

# --- Database -----------------------------------------------------------
# Leave unset to use local SQLite (./dev.db) — good for local dev without a
# Neon account. For real Postgres, use Neon's POOLED connection string
# (the "-pooler" hostname), e.g.:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL=

# --- Auth -----------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Email reminders (Resend) — https://resend.com, free tier 3000/mo -------
# Without a verified sending domain, Resend only allows the "from" address
# onboarding@resend.dev, delivering only to the email you signed up with.
RESEND_API_KEY=
REMINDER_EMAIL_FROM=TransitOps <alerts@transitops.in>
LICENCE_EXPIRY_REMINDER_DAYS=60
# Demo-only: when set, every outgoing reminder email is redirected here
# instead of the real recipient (useful since seeded users have fake
# @transitops.in addresses). Leave unset in a real deployment.
DEMO_RECIPIENT_OVERRIDE=

# --- Document storage (Cloudinary) — https://cloudinary.com, free tier ------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Trip route visualization (Mapbox) — https://mapbox.com, free tier ------
MAPBOX_ACCESS_TOKEN=
