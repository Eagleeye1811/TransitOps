# Copy to .env.local for local dev overrides. Defaults to localhost:8000 if unset.
VITE_API_BASE_URL=http://localhost:8000

# Optional: enables the live trip-route map on the Trip Details page.
# Get a free token at https://account.mapbox.com/access-tokens/ (free tier
# is generous for demo/dev use). Without it, the map renders a graceful
# "token missing" placeholder instead of a live Mapbox map.
VITE_MAPBOX_TOKEN=
